class SahilException extends RuntimeException{
    public SahilException(String str) {
        super(str);
    }
}

public class Demo {
    public static void main(String[] args) {
        int i = 20;
        int j = 0;

        try {
            j = 15 / i;
            if (j==0){
                throw new SahilException("Zero as output is prohibited.");
            }

        }
        catch(SahilException e){
            System.out.println("Sahil Exception occurred.... " + e);
        }

        catch(Exception e){
            System.out.println("Something went wrong.." + e);
        }
        System.out.println(j);
        System.out.println("At the end of program..");
    }

}
