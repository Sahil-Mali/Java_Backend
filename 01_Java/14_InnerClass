//only inner class can be static.

class A{
    int A;
    public void show(){
        System.out.println("in show");
    }

    static class B{
        public void config(){
            System.out.println("in config");
        }
    }
}

public class Demo {
    public static void main(String[] args) {
        A obj = new A();
        obj.show();

        //below code works if inner class is non static.
//      A.B obj1 = obj.new B();
//      obj1.config();

        //below code works for static inner class.
        A.B obj2 = new A.B();
        obj2.config();

    }
}
