interface A{
    void show();
    void run();
}
interface B extends A{                 //interface extends interface

}
class C implements B{                  //class implements interface

    @Override
    public void show() {
        System.out.println("in show..");
    }

    @Override
    public void run() {
        System.out.println("in run..");
    }
}

public class Demo {
    public static void main(String[] args) {
        C obj = new C();
        obj.show();
        obj.run();
    }
}
